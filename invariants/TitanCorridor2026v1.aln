// Filename: invariants/TitanCorridor2026v1.aln

cross_shard_invariant TitanLyapunovNonExpansion2026v1 {
  inputs {
    plan       : RegionLinkPlan2026v1;
    ef_bounds  : TitanNetPlane.EFDelayBound2026v1;
    metrics    : TitanMetrics2026v1;
  }

  description "Lyapunov function V must be non-increasing per basin under Titan routing and EF delay bounds.";

  kernel_module  "titan-lyapunov-kernel";
  proof_module   "TitanRiskLyapunovRelation.tla";
  kernel_version "2026.1.3";

  requires forall basin_id in metrics.basins() {
    let v_t_series = metrics.V_series(basin_id);
    forall t in v_t_series.indices().window(2) {
      let v_t   = v_t_series[t];
      let v_tp1 = v_t_series[t + 1];
      v_tp1 - v_t <= 0.0
    }
  };
}

cross_plane_invariant TitanCannotWeakenWater2026v1 {
  inputs {
    water_corridors : WaterCorridorProfile2026v1;
    titan_corridors : TitanIntCorridorProfile2026v1;
  }

  description "TITAN risk envelopes may not exceed WATER envelopes for any shared risk coordinate.";

  kernel_module  "titan-corridor-kernel";
  proof_module   "TitanCrossPlaneMonotonicity.tla";
  kernel_version "2026.1.3";

  requires forall coord in water_corridors.risk_coordinates() {
    let w_min = water_corridors.min(coord);
    let w_max = water_corridors.max(coord);
    let t_min = titan_corridors.min(coord);
    let t_max = titan_corridors.max(coord);

    t_min >= w_min && t_max <= w_max
  };
}
